# ── OpenClaw MBC — Production Environment ─────────────────────────────────────
# Copy to .env and fill in the values

# Host for Traefik routing (same as orbit-core host)
MBC_HOST=prod.nesecurity.com.br

# Supabase (persistence)
SUPABASE_URL=https://ayjbdwwbhvdsltmvcgls.supabase.co
SUPABASE_SERVICE_ROLE_KEY=          # Supabase dashboard → Settings → API → service_role

# WhatsApp API (Evolution API on prod)
WHATSAPP_API_URL=                   # e.g. http://evolution_evolution_api:8080
WHATSAPP_API_KEY=                   # Evolution API global key
WHATSAPP_INSTANCE=mbc               # Instance name in Evolution API

# Webhook security
WEBHOOK_SECRET=                     # openssl rand -hex 32 — shared with WhatsApp provider

# Orbit-core integration (monitoring/alerting)
ORBIT_CORE_URL=http://orbitcore_api:3010
ORBIT_API_KEY=                      # orbit-core admin API key

# Vite build-time vars (for frontend)
VITE_SUPABASE_URL=https://ayjbdwwbhvdsltmvcgls.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=      # anon key from Supabase
